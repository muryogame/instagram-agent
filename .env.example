# Instagram Graph API credentials（Businessアカウント用）
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Claude API（コンテンツ生成 + 画像プロンプト生成）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 導線URL（bio linkやストーリーリンク）
NOTE_PROFILE_URL=https://note.com/your_profile
AFFILIATE_URL=https://your-affiliate-link.com
LINE_URL=https://line.me/ti/p/your_line_id
LINKTREE_URL=https://linktr.ee/your_profile

# 画像生成（Stability AI / Unsplash）
STABILITY_API_KEY=
UNSPLASH_ACCESS_KEY=

# Slack通知（任意）
SLACK_WEBHOOK_URL=

# 投稿設定
DAILY_POST_LIMIT=3
MIN_INTERVAL_MINUTES=60
DRY_RUN=false
